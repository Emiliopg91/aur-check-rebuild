 #!/bin/bash

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

sudo install -Dm644 "$DIR/hooks/zz-aur-check-rebuild.hook" "/usr/share/libalpm/hooks/zz-aur-check-rebuild.hook"
sudo install -Dm755 "$DIR/scripts/aur-check-rebuild.py" "/usr/share/libalpm/scripts/aur-check-rebuild"
sudo install -Dm644 "$DIR/settings.json" "/usr/share/aur-check-rebuild/settings.json"
rm -f "$DIR/aur-check-rebuild.log" && touch "$DIR/aur-check-rebuild.log" && sudo install -Dm644 "$DIR/aur-check-rebuild.log" "/var/log/aur-check-rebuild.log"
